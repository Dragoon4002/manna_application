# Dependencies (all subdirectories)
**/node_modules
**/.pnp
**/.pnp.*
**/.yarn/*
!**/.yarn/patches
!**/.yarn/plugins
!**/.yarn/releases
!**/.yarn/versions

# Environment Variables (all subdirectories)
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local
**/.env*.local
!**/.env.sample
!**/.env.example

# Build Artifacts
**/dist
**/build
**/.next
**/out
**/target
**/cache
**/.cache
**/.parcel-cache
**/.turbo

# Foundry
**/cache
**/out
**/broadcast
**/artifacts

# Testing
**/coverage
**/.jest-cache
**/*.test.ts.snap

# Logs
**/*-debug.log*
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/.pnpm-debug.log*
**/lerna-debug.log*

# OS Files
**/.DS_Store
**/Thumbs.db
**/*.pem

# Editor
**/.vscode/*
!**/.vscode/extensions.json
!**/.vscode/settings.json
**/.idea
**/*.swp
**/*.swo
**/*~
**/.project
**/.classpath
**/.settings/

# TypeScript
**/*.tsbuildinfo
**/next-env.d.ts

# Deployment
**/.vercel
**/.netlify

# Temp Files
**/*.tmp
**/*.temp
**/.local

# Package Manager Locks
**/package-lock.json
**/yarn.lock
**/pnpm-lock.yaml

# Secrets & Keys
**/*.key
**/*.pem
**/secrets.json
**/credentials.json