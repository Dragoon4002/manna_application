AUTH_SECRET="" # Added by `npx auth secret`. Read more: https://cli.authjs.dev
HMAC_SECRET_KEY='some-secret' # create this by running `openssl rand -base64 32`
AUTH_URL='' # For testing this should be your NGROK URL and for production this should be your production URL
NEXT_PUBLIC_APP_ID='' # APP ID from the developer portal

# HumanDrop contracts (deploy with contracts/script/DeployAll.s.sol)
ARBITRUM_SEPOLIA_RPC='' # Tenderly Virtual TestNet RPC URL
NEXT_PUBLIC_HUMANDROP_ADDRESS='' # HumanDrop contract
NEXT_PUBLIC_WORLD_ID_VERIFIER_ADDRESS='' # WorldIDVerifier contract
NEXT_PUBLIC_HDT_ADDRESS='' # HumanDropToken contract
CRE_WORKFLOW_URL='' # CRE HTTP trigger URL
CREATOR_PRIVATE_KEY='' # Deployer private key for server-side contract writes

# Earn contracts
NEXT_PUBLIC_STAKING_VAULT_ADDRESS='' # StakingVault contract
NEXT_PUBLIC_BATCH_PAYOUT_ADDRESS='' # BatchPayout contract
NEXT_PUBLIC_VESTING_VAULT_ADDRESS='' # VestingVault contract

# Debug mode (bypasses World ID for local testing)
DEBUG_MODE=true
NEXT_PUBLIC_DEBUG_MODE=true
